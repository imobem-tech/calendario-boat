{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/agendar", "destination": "/agendar.html" },
    { "source": "/agendar.html", "destination": "/agendar.html" },
    { "source": "/:token([a-z]+)", "destination": "/index.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
